[Desktop Entry]
Name=HashMyFiles
GenericName=File Integrity Checker
Comment=Scan and verify file integrity using cryptographic hashes
Exec=hashmyfiles
Icon=hashmyfiles
Terminal=false
Type=Application
Categories=Utility;Security;System;
Keywords=hash;sha256;sha512;blake3;integrity;verify;checksum;
StartupWMClass=HashMyFiles
StartupNotify=true
